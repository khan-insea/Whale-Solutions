# =========================================================================
# WHALE AGENCY - ENVIRONMENT VARIABLES TEMPLATE
# =========================================================================
# Copy this file to '.env.local' and fill in your actual credentials.
# DO NOT commit '.env.local' or any other files containing real secrets to GitHub.
# =========================================================================

# ----------------------------------------------------
# SERVER-SIDE SECRETS (Never exposed to the client/browser)
# ----------------------------------------------------

# RESEND_API_KEY: The API token from Resend.com to enable physical email delivery.
RESEND_API_KEY=

# CONTACT_TO_EMAIL: The destination email address where contact form submissions are sent.
CONTACT_TO_EMAIL=

# CONTACT_FROM_EMAIL: The verified sender email address in your Resend account (e.g., info@yourdomain.com).
CONTACT_FROM_EMAIL=

# ADMIN_PASSWORD: The secure, strong password used to access the Admin Panel (/admin) and clean up queries.
ADMIN_PASSWORD=

# GEMINI_API_KEY: Optional API key for Google Gemini model generation if used on the server.
GEMINI_API_KEY=

# ----------------------------------------------------
# CLIENT-SIDE ENVIRONMENT VARIABLES (Exposed to the browser via Vite)
# ----------------------------------------------------

# VITE_SITE_URL: The public canon site URL of the web app (e.g., http://localhost:3000 or production domains)
VITE_SITE_URL=

# VITE_GA_ID: Google Analytics 4 Measurement ID (e.g., G-XXXXXXX)
VITE_GA_ID=

# VITE_CLARITY_ID: Microsoft Clarity project tracking ID
VITE_CLARITY_ID=

# VITE_SUPABASE_URL: Optional client URL connection to Supabase DB backend
VITE_SUPABASE_URL=

# VITE_SUPABASE_ANON_KEY: Optional anonymous API client key to query Supabase
VITE_SUPABASE_ANON_KEY=
