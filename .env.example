# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="https://whale-solutions-vn.vercel.app"

# CONTACT_TO_EMAIL: The destination email address where form submissions should be sent.
CONTACT_TO_EMAIL="insightads.vn@gmail.com"

# RESEND_API_KEY: The API token from Resend.com to enable physical email delivery.
RESEND_API_KEY="YOUR_RESEND_API_KEY"

# CONTACT_FROM_EMAIL: The sender address verified in your Resend account (e.g. contact@yourdomain.com).
CONTACT_FROM_EMAIL="Whale Solutions <onboarding@resend.dev>"

# ADMIN_PASSWORD: The custom password used to protect and authorize access to the Admin Dashboard and submissions.
ADMIN_PASSWORD="whale-solutions-admin"

# SITE URL for redirection & SEO canonical pathing
NEXT_PUBLIC_SITE_URL="https://www.khansea.io.vn/"

# Analytics & Tracking integrations
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_CLARITY_ID=""

# Supabase database config (optional cloud scaling database placeholders)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
